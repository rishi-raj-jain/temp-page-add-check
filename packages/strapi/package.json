{
  "name": "@creem_io/strapi",
  "version": "0.0.1",
  "description": "Official Creem plugin for Strapi 5. Manage products, subscriptions, and checkout directly from the Strapi admin panel.",
  "keywords": [
    "strapi",
    "creem",
    "payments",
    "checkout",
    "billing",
    "subscriptions",
    "merchant-of-record"
  ],
  "license": "MIT",
  "author": {
    "name": "Creem",
    "url": "https://creem.io"
  },
  "contributors": [
    {
      "name": "Rishi Raj Jain",
      "url": "https://rishi.app"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/armitage-labs/creem.git",
    "directory": "packages/strapi"
  },
  "homepage": "https://github.com/armitage-labs/creem/tree/main/packages/strapi",
  "bugs": {
    "url": "https://github.com/armitage-labs/creem/issues"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "typecheck": "tsc -p admin/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.16.0"
  },
  "devDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.1.0",
    "@strapi/strapi": "^5.44.0",
    "@strapi/typescript-utils": "^5.44.0",
    "@types/node": "^25.9.3",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "6.6.2",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.1",
    "typescript": "5.3.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/sdk-plugin": "^6.1.0",
    "@strapi/strapi": "^5.44.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.6.2",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.4.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "strapi": {
    "kind": "plugin",
    "name": "strapi5-plugin-for-creem",
    "displayName": "Strapi 5 Plugin for Creem",
    "description": "Official Creem plugin for Strapi 5 — manage products, subscriptions, and checkout directly from the Strapi admin panel."
  }
}
