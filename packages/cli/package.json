{
  "name": "@creem_io/cli",
  "version": "0.2.2",
  "description": "Official CLI for Creem - the Stripe alternative for SaaS",
  "keywords": [
    "creem",
    "cli",
    "payments",
    "saas",
    "subscriptions"
  ],
  "author": "Creem <support@creem.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/armitage-labs/creem.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/armitage-labs/creem/tree/main/packages/cli",
  "bugs": "https://github.com/armitage-labs/creem/issues",
  "bin": {
    "creem": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
