    "autoprefixer": "^10.4.24",
    "framer-plugin-tools": "^1.2.2",
    "postcss": "^8.5.6",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.0",
