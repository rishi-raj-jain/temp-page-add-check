  "type": "module",
  "private": true,
  "author": {
    "name": "Creem",
    "url": "https://creem.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/armitage-labs/creem.git",
    "directory": "packages/framer"
  },
  "homepage": "https://github.com/armitage-labs/creem/tree/main/packages/framer",
  "bugs": {
