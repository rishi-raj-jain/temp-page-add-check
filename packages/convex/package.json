{
  "name": "@creem_io/convex",
  "description": "A Creem component for Convex.",
  "author": "Micha Mailaender",
  "repository": {
    "type": "git",
    "url": "https://github.com/armitage-labs/creem.git",
    "directory": "packages/convex"
  },
  "homepage": "https://github.com/armitage-labs/creem/tree/main/packages/convex",
  "bugs": {
    "url": "https://github.com/armitage-labs/creem/issues"
  },
  "version": "0.3.2",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "convex",
    "component",
    "creem",
    "stripe",
    "subscription",
    "billing",
    "payments",
    "checkout"
  ],
  "type": "module",
  "sideEffects": [
    "./src/client/polyfill.ts",
    "./dist/client/polyfill.js"
  ],
  "scripts": {
    "dev:react": "concurrently --kill-others --prefix-colors 'blue,yellow,magenta' --names 'frontend,backend,build' 'pnpm dev:frontend:react' 'pnpm dev:backend' 'pnpm dev:build'",
    "dev:svelte": "concurrently --kill-others --prefix-colors 'blue,yellow,magenta' --names 'frontend,backend,build' 'pnpm dev:frontend:svelte' 'pnpm dev:backend' 'pnpm dev:build'",
    "dev:backend": "convex dev --typecheck-components",
    "dev:frontend:react": "vite --clearScreen false --config example-react/vite.config.ts",
    "dev:frontend:svelte": "vite --clearScreen false --config example-svelte/vite.config.ts",
    "dev:build": "chokidar 'tsconfig*.json' 'src/**/*.ts' 'src/**/*.tsx' 'src/**/*.svelte' -i '**/*.test.ts' -i '**/*.test.tsx' -c 'npx convex codegen --component-dir ./src/component && pnpm build' --initial",
    "predev": "convex dev --skip-push",
    "clean": "rm -rf dist *.tsbuildinfo",
    "build": "tsc --project ./tsconfig.build.json && cpy '**/*.svelte' '../../dist/svelte/' --cwd=src/svelte",
    "typecheck": "tsc --noEmit -p ./tsconfig.json && tsc --noEmit -p ./convex/tsconfig.json && tsc --noEmit -p ./example-react/tsconfig.json && tsc --noEmit -p ./example-svelte/tsconfig.json",
    "format": "prettier --write .",
    "lint": "eslint .",
    "all": "concurrently --kill-others --prefix-colors 'blue,yellow,magenta,cyan' --names 'frontend,backend,build,test' 'pnpm dev:frontend:react' 'pnpm dev:backend' 'pnpm dev:build' 'pnpm test:watch'",
    "test": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest run --typecheck",
    "test:watch": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest --typecheck --clearScreen false",
    "test:debug": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp vitest run --coverage --coverage.reporter=text",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./styles": "./src/library.css",
    "./test": "./src/test.ts",
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    }
  },
  "peerDependencies": {
    "@ark-ui/react": "^5.31.0",
    "@ark-ui/svelte": "^5.16.0",
    "convex": "^1.29.0",
    "@mmailaender/convex-svelte": ">=0.16.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "svelte": "^5"
  },
  "peerDependenciesMeta": {
    "@ark-ui/react": {
      "optional": true
    },
    "@ark-ui/svelte": {
      "optional": true
    },
    "@mmailaender/convex-svelte": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@ark-ui/react": "^5.31.0",
    "@ark-ui/svelte": "^5.16.0",
    "@convex-dev/eslint-plugin": "1.1.1",
    "@edge-runtime/vm": "5.0.0",
    "@eslint/eslintrc": "3.3.4",
    "@eslint/js": "9.39.2",
    "@lucide/svelte": "^0.575.0",
    "@mmailaender/convex-svelte": "^0.16.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-table": "8.21.3",
    "@types/node": "20.19.35",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "autoprefixer": "10.4.27",
    "chokidar-cli": "3.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "concurrently": "^9.2.1",
    "convex": "1.32.0",
    "convex-helpers": "0.1.114",
    "convex-test": "0.0.41",
    "cpy-cli": "7.0.0",
    "eslint": "9.39.3",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "17.3.0",
    "jsdom": "^28.1.0",
    "lucide-react": "0.575.0",
    "next-themes": "0.4.6",
    "path-exists-cli": "2.0.0",
    "pkg-pr-new": "0.0.65",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remeda": "2.33.6",
    "svelte-eslint-parser": "^1.5.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "use-debounce": "10.1.0",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "wrangler": "4.69.0"
  },
  "types": "./dist/client/index.d.ts",
  "module": "./dist/client/index.js",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "buffer": "^6.0.3",
    "creem": "^1.5.3",
    "convex-helpers": "^0.1.63",
    "marked": "^17.0.3",
    "remeda": "^2.20.2",
    "standardwebhooks": "^1.0.0"
  }
}
