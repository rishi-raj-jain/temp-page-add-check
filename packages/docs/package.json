{
  "name": "creem-docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "format": "prettier --write \"**/*.{json,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{json,md,mdx}\"",
    "generate:api": "node scripts/generate-api-docs.js",
    "generate:api:remote": "node scripts/generate-api-docs.js --update-spec --cleanup --url",
    "generate:api:dry-run": "node scripts/generate-api-docs.js --dry-run",
    "generate:api:cleanup": "node scripts/generate-api-docs.js --cleanup"
  },
  "devDependencies": {
    "prettier": "^3.1.0"
  }
}
